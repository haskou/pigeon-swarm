PORT=8080
LOG_LEVEL=info
IPFS_STORAGE_HOST_PATH=./ipfs_storage
LOCAL_STORAGE_HOST_PATH=./local_storage
LINK_PREVIEW_RATE_LIMIT_PER_MINUTE=30
PIGEON_RELAY_DATA_LIMIT_BYTES=67108864

# Required by both the backend and coturn. Generate with:
# openssl rand -hex 32
# Every backend and coturn instance in the same relay pool must share it.
CALLS_TURN_SHARED_SECRET=
CALLS_TURN_PORT=3478
# Optional override. Leave empty to detect the public IPv4 address at startup.
CALLS_TURN_EXTERNAL_IP=
CALLS_TURN_RELAY_MIN_PORT=49160
CALLS_TURN_RELAY_MAX_PORT=49200
CALLS_TURN_REALM=pigeon-swarm
CALLS_TURN_TRANSPORTS=udp,tcp
CALLS_ICE_TRANSPORT_POLICY=all

# Optional explicit URLs. Normally the backend derives them from the node's
# publicHost and callsRelay.port configuration.
CALLS_TURN_URLS=

# Docker Compose persists data in host folders by default.

# Optional: fill these with your own generated VAPID values to enable Web Push.
PUSH_VAPID_PUBLIC_KEY=
PUSH_VAPID_PRIVATE_KEY=
PUSH_VAPID_SUBJECT=
