PORT=8080
LOG_LEVEL=info
IPFS_STORAGE_HOST_PATH=./ipfs_storage
LOCAL_STORAGE_HOST_PATH=./local_storage
LINK_PREVIEW_RATE_LIMIT_PER_MINUTE=30
PIGEON_RELAY_DATA_LIMIT_BYTES=67108864

# Docker Compose persists data in host folders by default.

# Optional: fill these with your own generated VAPID values to enable Web Push.
PUSH_VAPID_PUBLIC_KEY=
PUSH_VAPID_PRIVATE_KEY=
PUSH_VAPID_SUBJECT=
